# ───────── Supabase (baza + auth + storage) ─────────
# Adres URL projektu Supabase (np. https://abcd.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Klucz "anon" (public). Bezpieczny do użycia w przeglądarce.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Klucz "service_role" (TYLKO server-side). NIGDY nie commituj prawdziwego klucza.
# Używany do importu CSV katalogu (omija RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Nazwa bucketa Storage z obrazami realizacji
NEXT_PUBLIC_SUPABASE_BUCKET=realizacje

# ───────── Backend G-Lab (Render) ─────────
# Adres backendu - włącza upload obrazów z konwersją (AVIF/WebP/JPG)
# oraz skrzynkę zapytań w panelu /leads.
# Bez tej zmiennej panel działa, ale w trybie ograniczonym (upload bezpośrednio do Supabase, brak skrzynki).
NEXT_PUBLIC_BACKEND_URL=

# ───────── Strona publiczna ─────────
# Adres strony publicznej - używany przez przyciski "Otwórz na stronie" w panelu.
NEXT_PUBLIC_SITE_URL=

# ───────── Revalidate webhook (opcjonalnie) ─────────
# Wspólny sekret używany do triggera rebuildu strony statycznej po zapisie w panelu.
# Wartość MUSI być identyczna z REVALIDATE_SECRET ustawionym na backendzie.
REVALIDATE_SECRET=
